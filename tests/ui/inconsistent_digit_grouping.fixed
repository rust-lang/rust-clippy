#[warn(clippy::inconsistent_digit_grouping)]
#[deny(clippy::unreadable_literal)]
#[allow(unused_variables, clippy::excessive_precision)]
fn main() {
    let good = (
        123,
        1_234,
        1_2345_6789,
        123_f32,
        1_234.12_f32,
        1_234.123_4_f32,
        1.123_456_7_f32,
    );
    let bad = (123_456, 12_345_678, 1_234_567, 1.234_567_8_f32);
    //~^ inconsistent_digit_grouping
    //~| inconsistent_digit_grouping
    //~| inconsistent_digit_grouping
    //~| inconsistent_digit_grouping

    // Test padding
    let _ = 0x10_0000;
    //~^ unreadable_literal
    let _ = 0x100_0000;
    //~^ unreadable_literal
    let _ = 0x1000_0000;
    //~^ unreadable_literal
    let _ = 0x1_0000_0000_u64;
    //~^ unreadable_literal

    // Test suggestion when fraction has no digits
    let _: f32 = 123_456.;
    //~^ inconsistent_digit_grouping

    // Test UUID formatted literal
    let _: u128 = 0x12345678_1234_1234_1234_123456789012;

    {
        macro_rules! mac1 {
            () => {
                123_456 //~ inconsistent_digit_grouping
            };
        }
        macro_rules! mac2 {
            () => {
                1_234.5678_f32
            };
        }

        let _ = mac1!();
        let _ = mac2!();
    }

    // Issue #6096
    // Allow separating exponent with '_'
    let _ = 1.025_011_10_E0;
}
