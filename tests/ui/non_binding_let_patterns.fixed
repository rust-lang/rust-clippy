#![warn(clippy::non_binding_let_patterns)]
#![allow(
    irrefutable_let_patterns,
    clippy::eq_op,
    clippy::needless_ifs,
    clippy::never_loop,
    clippy::partialeq_to_none,
    clippy::redundant_pattern_matching,
    clippy::while_immutable_condition
)]

#[derive(PartialEq)]
struct Point {
    x: i32,
    y: i32,
}

enum Status {
    Ok,
    Err(i32),
}

fn main() {
    let tuple = (4, 7);
    let opt = Some(42);
    let pt = Point { x: 1, y: 2 };
    let status = Status::Ok;

    // --- let-else cases ---

    if 1 != 0 { return }
    //~^ non_binding_let_patterns

    if opt != Some(42) { return }
    //~^ non_binding_let_patterns

    if opt != None { return }
    //~^ non_binding_let_patterns

    if !matches!(status, Status::Err(_)) { return }
    //~^ non_binding_let_patterns

    // --- if-let cases ---

    if 42 == 42 {}
    //~^ non_binding_let_patterns

    if tuple == (6, 7) {}
    //~^ non_binding_let_patterns

    if pt == (Point { x: 1, y: 2 }) {}
    //~^ non_binding_let_patterns

    if matches!(status, Status::Ok) {}
    //~^ non_binding_let_patterns

    // --- while-let cases ---

    let mut x = 0;
    while x == 0 {
        //~^ non_binding_let_patterns
        x += 1;
    }

    while opt == None {
        //~^ non_binding_let_patterns
        break;
    }

    // --- negative tests ---

    let val = 1 else { return };
    let (a, b) = tuple else { return };
    if let Some(x) = opt {}
    if let Some(Some(inner)) = Some(Some(10)) {}
    if let Point { x, y: 2 } = pt {}
    while let Status::Err(e) = status {
        break;
    }
}
