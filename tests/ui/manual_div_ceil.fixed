#![warn(clippy::manual_div_ceil)]
#![feature(int_roundings)]

fn main() {
    let x = 7_i32;
    let y = 4_i32;

    // Lint.
    let _ = x.div_ceil(y);
    let _ = x.div_ceil(y);
    let _ = x.div_ceil(y);

    let _ = 7_i32.div_ceil(4);

    // No lint.
    let _ = (x + (y - 2)) / y;
    let _ = (x + (y + 1)) / y;

    let z = 3_i32;
    let _ = (x + (y - 1)) / z;
}
