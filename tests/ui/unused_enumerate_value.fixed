#![warn(clippy::unused_enumerate_value)]

fn main() {
    let mut array = [1, 2, 3];
    for index in 0..array.len() {
        //~^ unused_enumerate_value
        println!("{}", index);
    }

    let my_iter = vec![1, 2, 3].into_iter();
    for index in 0..my_iter.len() {
        //~^ unused_enumerate_value
        println!("{}", index);
    }
}
